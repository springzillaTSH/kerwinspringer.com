<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Diagram Cropper — Kairu MCQ</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,'Poppins',sans-serif;background:#1a2332;color:#f5f5f7;padding:20px;line-height:1.4}
h1{font-size:22px;margin-bottom:6px;color:#fbbf24}
.subtitle{font-size:13px;color:#a1a1a6;margin-bottom:16px}
.toolbar{position:sticky;top:0;background:#0f1825;padding:14px 18px;border-radius:12px;margin-bottom:18px;display:flex;gap:14px;align-items:center;z-index:10;border:1px solid #2c3a4f;box-shadow:0 4px 16px rgba(0,0,0,0.4)}
.toolbar button{background:#fbbf24;color:#0f1825;border:none;padding:10px 18px;border-radius:8px;font-weight:700;cursor:pointer;font-family:inherit;font-size:13px}
.toolbar button:hover{background:#f59e0b}
.toolbar .count{margin-left:auto;font-size:12px;color:#a1a1a6}
.toolbar .nav{display:flex;gap:4px;overflow-x:auto;flex:1;min-width:0;scrollbar-width:thin;scrollbar-color:#2c3a4f #0f1825;padding-bottom:4px}
.toolbar .nav::-webkit-scrollbar{height:6px}
.toolbar .nav::-webkit-scrollbar-thumb{background:#2c3a4f;border-radius:3px}
.toolbar .nav button{background:#2c3a4f;color:#f5f5f7;padding:8px 10px;font-size:12px;font-weight:700;border:none;border-radius:6px;cursor:pointer;font-family:inherit;flex-shrink:0;white-space:nowrap;transition:background .15s}
.toolbar .nav button[data-subj="bio"]{border-bottom:3px solid rgba(34,197,94,0.5)}
.toolbar .nav button[data-subj="it"]{border-bottom:3px solid rgba(59,130,246,0.5)}
.toolbar .nav button:hover{background:#3a4a64}
.toolbar .nav button.active{background:#fbbf24;color:#0f1825;border-bottom-color:#fbbf24}
.diagram{background:#0f1825;border:1px solid #2c3a4f;border-radius:12px;padding:18px;margin-bottom:18px;display:none}
.diagram.active{display:block}
.diagram-head{display:flex;align-items:baseline;gap:12px;margin-bottom:12px}
.diagram-head h2{font-size:18px;color:#fbbf24}
.diagram-head .src{font-size:11px;color:#6e6e73;font-family:monospace}
.diagram-head .stem{font-size:12px;color:#a1a1a6;margin-top:4px;display:block;flex:1}
.diagram-body{display:grid;grid-template-columns:1fr 360px;gap:16px}
@media (max-width:1100px){.diagram-body{grid-template-columns:1fr}}

.canvas-wrap{position:relative;background:#fff;border-radius:8px;overflow:hidden;line-height:0;align-self:start}
.canvas-wrap canvas{display:block;width:100%;height:auto;cursor:crosshair}

.controls{display:flex;flex-direction:column;gap:10px}
.control{display:flex;flex-direction:column;gap:4px;background:#1a2332;padding:10px 12px;border-radius:8px;border:1px solid #2c3a4f}
.control label{font-size:11px;color:#a1a1a6;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;display:flex;justify-content:space-between}
.control label span{color:#fbbf24;font-family:monospace;font-size:13px;text-transform:none;letter-spacing:0}
.control input[type=range]{width:100%;height:4px;background:#2c3a4f;outline:none;-webkit-appearance:none;border-radius:2px;margin:6px 0}
.control input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;background:#fbbf24;border-radius:50%;cursor:pointer}
.control input[type=number]{background:#0f1825;border:1px solid #2c3a4f;color:#f5f5f7;padding:6px 8px;border-radius:6px;font-family:monospace;font-size:13px;width:100%}

.preview{background:#fff;border-radius:8px;padding:8px;margin-top:8px}
.preview-title{font-size:11px;color:#6e6e73;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;color:#a1a1a6}
.preview canvas{display:block;max-width:100%;background:#fff;border:1px solid #2c3a4f;border-radius:4px}

.copy-modal{position:fixed;inset:0;background:rgba(0,0,0,0.85);display:none;align-items:center;justify-content:center;z-index:100;padding:20px}
.copy-modal.open{display:flex}
.copy-modal-card{background:#1a2332;border:1px solid #2c3a4f;border-radius:12px;padding:22px;max-width:780px;width:100%;max-height:80vh;overflow:auto}
.copy-modal h3{color:#fbbf24;margin-bottom:12px}
.copy-modal textarea{width:100%;height:380px;font-family:monospace;font-size:12px;background:#0f1825;color:#f5f5f7;border:1px solid #2c3a4f;border-radius:8px;padding:12px;resize:vertical}
.copy-modal-actions{display:flex;gap:10px;margin-top:12px}
.copy-modal-actions button{flex:1;padding:10px;border:none;border-radius:8px;font-weight:700;cursor:pointer;font-family:inherit;font-size:13px}
.copy-modal-actions .copy-btn{background:#fbbf24;color:#0f1825}
.copy-modal-actions .close-btn{background:#2c3a4f;color:#f5f5f7}

.info-strip{background:rgba(245,166,35,0.08);border:1px solid rgba(245,166,35,0.3);border-radius:10px;padding:12px 16px;margin-bottom:16px;font-size:12px;color:#fde68a;line-height:1.55}
.info-strip strong{color:#fbbf24}
</style>
</head>
<body>

<h1>📐 Diagram Cropper — Kairu MCQ</h1>
<div class="subtitle">Adjust X / Y / Width / Height for each diagram. Live preview shows the crop result. Click <strong>Copy all parameters</strong> when done.</div>

<div class="toolbar">
  <div class="nav" id="diagramNav"></div>
  <span class="count" id="counter">—</span>
  <button id="copyBtn">Copy all parameters →</button>
</div>

<div class="info-strip">
  <strong>Toolbar:</strong> Buttons show the original question number from the paper (e.g. <code>Q11</code>). Hover for full details. <strong>Numbers are not consecutive</strong> — text-only questions are skipped (they have no diagram). Bio = green underline, IT = blue underline.
</div>
<div id="diagrams"></div>

<div class="copy-modal" id="copyModal">
  <div class="copy-modal-card">
    <h3>Crop parameters</h3>
    <p style="font-size:13px;color:#a1a1a6;margin-bottom:8px">Copy this and paste back to Kairu. Use Ctrl/Cmd+A to select all then Ctrl/Cmd+C.</p>
    <textarea id="copyText" readonly></textarea>
    <div class="copy-modal-actions">
      <button class="copy-btn" id="doCopy">Copy to clipboard</button>
      <button class="close-btn" id="closeModal">Close</button>
    </div>
  </div>
</div>

<script>
// === Initial diagram configs (best-guess starting crops) ===
const DIAGRAMS = [
  {id: 'ss19-001-family-tree', src: 'cropper-pages/ss2019mj/page-02.png', x: 130, y: 100, w: 1000, h: 380, stem: 'Smith family tree (used by Q1, Q2, Q3) — James Smith × Susan Harris with children Melissa, Jason, Diane, Stephani'}
];

const wrap = document.getElementById('diagrams');
const nav = document.getElementById('diagramNav');
const counter = document.getElementById('counter');
let activeId = DIAGRAMS[0].id;
const imageCache = {};

// Build nav buttons — compact, show Q-number with hover tooltip
DIAGRAMS.forEach((d, i)=>{
  const b = document.createElement('button');
  const m = d.id.match(/-(\d+)/);
  const qNum = m ? 'Q' + parseInt(m[1], 10) : d.id;
  // Bio uses one colour, IT uses another — visual grouping
  const subj = d.id.startsWith('bio') ? 'bio' : 'it';
  b.dataset.subj = subj;
  b.textContent = qNum;
  b.dataset.id = d.id;
  b.dataset.pos = i + 1;
  b.title = (i+1) + ' / ' + DIAGRAMS.length + ' — ' + d.id + ' — ' + d.stem;
  b.addEventListener('click', ()=>setActive(d.id));
  nav.appendChild(b);
});

function setActive(id){
  activeId = id;
  document.querySelectorAll('.diagram').forEach(el=>el.classList.toggle('active', el.dataset.id === id));
  document.querySelectorAll('#diagramNav button').forEach(el=>el.classList.toggle('active', el.dataset.id === id));
  const idx = DIAGRAMS.findIndex(d=>d.id===id);
  counter.textContent = `${idx+1} / ${DIAGRAMS.length}`;
}

// Build cards for each diagram
DIAGRAMS.forEach(d=>{
  const card = document.createElement('div');
  card.className = 'diagram';
  card.dataset.id = d.id;
  card.innerHTML = `
    <div class="diagram-head">
      <h2>${d.id}</h2>
      <span class="src">${d.src}</span>
      <span class="stem">${d.stem}</span>
    </div>
    <div class="diagram-body">
      <div>
        <div class="canvas-wrap"><canvas id="cv-${d.id}"></canvas></div>
      </div>
      <div class="controls">
        <div class="control">
          <label>X (left)<span id="lx-${d.id}">${d.x}</span></label>
          <input type="range" min="0" max="1275" value="${d.x}" id="rx-${d.id}">
          <input type="number" min="0" value="${d.x}" id="ix-${d.id}">
        </div>
        <div class="control">
          <label>Y (top)<span id="ly-${d.id}">${d.y}</span></label>
          <input type="range" min="0" max="1651" value="${d.y}" id="ry-${d.id}">
          <input type="number" min="0" value="${d.y}" id="iy-${d.id}">
        </div>
        <div class="control">
          <label>Width<span id="lw-${d.id}">${d.w}</span></label>
          <input type="range" min="50" max="1275" value="${d.w}" id="rw-${d.id}">
          <input type="number" min="50" value="${d.w}" id="iw-${d.id}">
        </div>
        <div class="control">
          <label>Height<span id="lh-${d.id}">${d.h}</span></label>
          <input type="range" min="50" max="1651" value="${d.h}" id="rh-${d.id}">
          <input type="number" min="50" value="${d.h}" id="ih-${d.id}">
        </div>
        <div class="preview">
          <div class="preview-title">Cropped preview</div>
          <canvas id="pv-${d.id}"></canvas>
        </div>
      </div>
    </div>
  `;
  wrap.appendChild(card);
});

// Set first active
setActive(activeId);

// Load images and set up handlers per diagram
DIAGRAMS.forEach(d=>{
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.src = d.src;
  img.onload = ()=>{
    imageCache[d.id] = img;
    drawCanvas(d);
    drawPreview(d);
  };
  img.onerror = ()=>{
    const cv = document.getElementById('cv-'+d.id);
    const ctx = cv.getContext('2d');
    cv.width = 400; cv.height = 200;
    ctx.fillStyle = '#fee'; ctx.fillRect(0,0,400,200);
    ctx.fillStyle = '#900'; ctx.font = '14px monospace';
    ctx.fillText('Failed to load: '+d.src, 10, 30);
    ctx.fillText('Make sure localhost:8000 is serving site-mockup', 10, 60);
  };

  const sync = (axis)=>{
    const r = document.getElementById('r'+axis+'-'+d.id);
    const i = document.getElementById('i'+axis+'-'+d.id);
    const l = document.getElementById('l'+axis+'-'+d.id);
    const update = (val)=>{
      d[axis] = parseInt(val,10) || 0;
      r.value = d[axis]; i.value = d[axis]; l.textContent = d[axis];
      drawCanvas(d); drawPreview(d);
    };
    r.addEventListener('input', e=>update(e.target.value));
    i.addEventListener('input', e=>update(e.target.value));
  };
  ['x','y','w','h'].forEach(sync);

  // Click and drag on canvas to set crop region
  const cv = document.getElementById('cv-'+d.id);
  let dragging=false, dragStart=null;
  cv.addEventListener('mousedown', e=>{
    const rect = cv.getBoundingClientRect();
    const scale = imageCache[d.id] ? imageCache[d.id].naturalWidth / rect.width : 1;
    dragStart = {x: Math.round((e.clientX-rect.left)*scale), y: Math.round((e.clientY-rect.top)*scale)};
    dragging = true;
  });
  cv.addEventListener('mousemove', e=>{
    if(!dragging) return;
    const rect = cv.getBoundingClientRect();
    const scale = imageCache[d.id] ? imageCache[d.id].naturalWidth / rect.width : 1;
    const cx = Math.round((e.clientX-rect.left)*scale);
    const cy = Math.round((e.clientY-rect.top)*scale);
    const nx = Math.min(dragStart.x, cx);
    const ny = Math.min(dragStart.y, cy);
    const nw = Math.abs(cx-dragStart.x);
    const nh = Math.abs(cy-dragStart.y);
    if(nw < 20 || nh < 20) return;
    d.x = nx; d.y = ny; d.w = nw; d.h = nh;
    ['x','y','w','h'].forEach(a=>{
      document.getElementById('r'+a+'-'+d.id).value = d[a];
      document.getElementById('i'+a+'-'+d.id).value = d[a];
      document.getElementById('l'+a+'-'+d.id).textContent = d[a];
    });
    drawCanvas(d); drawPreview(d);
  });
  cv.addEventListener('mouseup', ()=>dragging=false);
  cv.addEventListener('mouseleave', ()=>dragging=false);
});

function drawCanvas(d){
  const img = imageCache[d.id]; if(!img) return;
  const cv = document.getElementById('cv-'+d.id);
  cv.width = img.naturalWidth; cv.height = img.naturalHeight;
  const ctx = cv.getContext('2d');
  ctx.drawImage(img, 0, 0);
  // Dim outside crop area
  ctx.fillStyle = 'rgba(0,0,0,0.55)';
  ctx.fillRect(0, 0, cv.width, d.y);                    // top
  ctx.fillRect(0, d.y, d.x, d.h);                       // left
  ctx.fillRect(d.x+d.w, d.y, cv.width-(d.x+d.w), d.h);  // right
  ctx.fillRect(0, d.y+d.h, cv.width, cv.height-(d.y+d.h)); // bottom
  // Crop rectangle border
  ctx.strokeStyle = '#fbbf24'; ctx.lineWidth = 4;
  ctx.strokeRect(d.x, d.y, d.w, d.h);
  // Corner handles
  ctx.fillStyle = '#fbbf24';
  const HS = 12;
  [[d.x,d.y],[d.x+d.w,d.y],[d.x,d.y+d.h],[d.x+d.w,d.y+d.h]].forEach(([cx,cy])=>{
    ctx.fillRect(cx-HS/2, cy-HS/2, HS, HS);
  });
}

function drawPreview(d){
  const img = imageCache[d.id]; if(!img) return;
  const pv = document.getElementById('pv-'+d.id);
  const maxW = 320;
  const scale = Math.min(1, maxW / d.w);
  pv.width = Math.max(1, Math.round(d.w * scale));
  pv.height = Math.max(1, Math.round(d.h * scale));
  const ctx = pv.getContext('2d');
  ctx.drawImage(img, d.x, d.y, d.w, d.h, 0, 0, pv.width, pv.height);
}

// Copy modal
document.getElementById('copyBtn').addEventListener('click', ()=>{
  const data = DIAGRAMS.map(d=>({id:d.id, src:d.src, x:d.x, y:d.y, w:d.w, h:d.h}));
  document.getElementById('copyText').value = JSON.stringify(data, null, 2);
  document.getElementById('copyModal').classList.add('open');
});
document.getElementById('closeModal').addEventListener('click', ()=>{
  document.getElementById('copyModal').classList.remove('open');
});
document.getElementById('doCopy').addEventListener('click', async ()=>{
  const ta = document.getElementById('copyText');
  ta.select();
  try {
    await navigator.clipboard.writeText(ta.value);
    document.getElementById('doCopy').textContent = 'Copied ✓';
    setTimeout(()=>document.getElementById('doCopy').textContent = 'Copy to clipboard', 2000);
  } catch(e) {
    document.execCommand('copy');
  }
});
</script>

</body>
</html>
